{
	"name": "julia-sanfrancisco",
	"version": "0.0.0-development",
	"private": true,
	"scripts": {
		"start": "concurrently \"typesafe-i18n\" \"npm run dev\"",
		"dev": "vite dev --host",
		"build": "NODE_OPTIONS=--no-deprecation WRANGLER_WRITE_LOGS=false vite build",
		"preview": "vite preview",
		"test": "npm run test:unit && npm run test:e2e",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"check": "NODE_OPTIONS=--no-deprecation svelte-kit sync && NODE_OPTIONS=--no-deprecation svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"typesafe-i18n": "typesafe-i18n"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.5.27",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"concurrently": "^8.0.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^16.5.0",
		"prettier": "^3.1.0",
		"prettier-plugin-svelte": "^3.2.6",
		"sass": "^1.62.0",
		"semantic-release": "^21.0.2",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tslib": "^2.4.1",
		"typesafe-i18n": "^5.24.3",
		"typescript": "^5.5.0",
		"typescript-eslint": "^8.62.1",
		"vite": "^7",
		"vitest": "^4.1.9",
		"wrangler": "^4.54.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fmaclen/julia-sanfrancisco.git"
	},
	"homepage": "https://julia.fernando.is/",
	"type": "module"
}
